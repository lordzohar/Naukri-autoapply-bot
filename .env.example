# Naukri Auto-Apply Bot Configuration
# Copy this file to .env and fill in your details
# NEVER commit .env to git (it's in .gitignore)

# Your Naukri.com login credentials
NAUKRI_EMAIL=your_email@example.com
NAUKRI_PASSWORD=your_password

# Your personal details (used for custom first/last name fields on some applications)
FIRSTNAME=YourFirstName
LASTNAME=YourLastName

# Job search keywords (comma-separated, e.g., "python developer, data analyst")
KEYWORDS=python developer, data analyst, software engineer

# Location filter (leave empty for all locations, or specify a city)
LOCATION=bangalore

# Number of search result pages to scrape per keyword (default: 2)
# Each keyword opens PAGES_PER_KEYWORD tabs simultaneously
PAGES_PER_KEYWORD=2

# Maximum number of jobs to apply per run
# Naukri typically allows ~100 applications per day
MAX_APPLICATIONS=50

# Browser configuration (only needed if NOT using webdriver-manager auto-detection)
# For Edge: path to msedgedriver.exe
# EDGE_DRIVER_PATH=C:\path\to\msedgedriver.exe
# For Firefox: path to Firefox profile root directory
# FIREFOX_PROFILE_PATH=C:\path\to\firefox\profile